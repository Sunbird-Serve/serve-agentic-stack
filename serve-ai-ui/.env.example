# SERVE AI UI Environment
REACT_APP_BACKEND_URL=http://localhost:8001

# Auth toggle
# "false" — Local dev, no Keycloak needed (role picker shown)
# "true"  — Keycloak OIDC login required (sandbox/production)
REACT_APP_AUTH_ENABLED=false

# Keycloak Configuration (only used when REACT_APP_AUTH_ENABLED=true)
# Local: http://localhost:8080
# Sandbox: https://auth.serve-v1.evean.net
# Production: https://auth.up.serve.net.in
REACT_APP_KEYCLOAK_URL=http://localhost:8080
REACT_APP_KEYCLOAK_REALM=sunbird-serve
