# SERVE Orchestrator Service Environment
PORT=8001
CORS_ORIGINS=*
MCP_SERVICE_URL=http://serve-agentic-mcp-service:8003
ONBOARDING_AGENT_URL=http://serve-onboarding-agent-service:8002
NEED_AGENT_URL=http://serve-need-agent-service:8005
ENGAGEMENT_AGENT_URL=http://serve-engagement-agent-service:8006
FULFILLMENT_AGENT_URL=http://serve-fulfillment-agent-service:8007
SELECTION_AGENT_URL=http://serve-selection-agent-service:8009

# LLM classifier for persona resolution (lightweight fallback)
# Uses a fast model to classify ambiguous first messages into personas
ANTHROPIC_API_KEY=your-anthropic-api-key
PERSONA_LLM_MODEL=claude-haiku-4-5-20251001

# WhatsApp Cloud API (Meta WABA)
WHATSAPP_TOKEN=your-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_APP_SECRET=your-app-secret
WHATSAPP_VERIFY_TOKEN=serve_verify_token
