# SERVE AI Platform - Environment Variables

# ── LLM Configuration (model-agnostic via LiteLLM) ──────────────────────────
# Set the API key for your chosen provider:
#   Anthropic: ANTHROPIC_API_KEY=sk-ant-...
#   OpenAI:    OPENAI_API_KEY=sk-...
#   Google:    GEMINI_API_KEY=...
# Legacy key (maps to ANTHROPIC_API_KEY if set):
EMERGENT_LLM_KEY=your-api-key-here

# Model names (LiteLLM format):
#   Anthropic: claude-haiku-4-5-20251001, claude-sonnet-4-5-20250929
#   OpenAI:    gpt-4o-mini, gpt-4o
#   Google:    gemini/gemini-2.0-flash
# LLM_MODEL=claude-sonnet-4-5-20250929

# Service Ports (defaults shown)
ORCHESTRATOR_PORT=8001
ONBOARDING_AGENT_PORT=8002
MCP_SERVICE_PORT=8003
FRONTEND_PORT=3000
NEED_START_DATE=2026-04-06
APPLICABLE_GRADES=6,7,8

FULFILL_API_PATH=/api/v1/serve-fulfill

DASHBOARD_API_KEY=SE20JSR26hXAPRrve

WHATSAPP_TOKEN=your_app_key_here
WHATSAPP_PHONE_NUMBER_ID=your_app_key_here
WHATSAPP_APP_SECRET=your_app_key_here
WHATSAPP_VERIFY_TOKEN=your_token_here

# Volunteer Registration URL — shown to unregistered recommended volunteers
VOLUNTEER_REGISTRATION_URL=https://serve-v1.evean.net

# Onboarding orientation videos
ONBOARDING_WELCOME_VIDEO_URL=
ONBOARDING_CLASSROOM_VIDEO_URL=

# Firebase API Key (for volunteer registration auth)
# DEPRECATED: Firebase replaced by Keycloak. Remove after migration confirmation.
# FIREBASE_API_KEY=your-firebase-key

# Keycloak Configuration
# Local: http://localhost:8080
# Sandbox: https://auth.serve-v1.evean.net
# Production: https://auth.up.serve.net.in
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=sunbird-serve

# Auth toggle — set to "false" for local dev without Keycloak
# When false: no JWT validation, dev user injected automatically
# When true: full Keycloak OIDC + JWT validation
AUTH_ENABLED=false

TEACHING_LANGUAGE=Hindi

# Nudge/Reminder System (WhatsApp only)
NUDGE_ENABLED=true
NUDGE_DELAY_1_MINUTES=60
NUDGE_DELAY_2_MINUTES=480
NUDGE_DELAY_3_MINUTES=1440
NUDGE_QUIET_HOURS_START=21
NUDGE_QUIET_HOURS_END=8
NUDGE_CHECK_INTERVAL_MINUTES=5
