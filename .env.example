# Environment Variables for SERVE AI
# Copy this file to .env and fill in values

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://serve:serve@localhost:5432/serve_db

# LLM Configuration
EMERGENT_LLM_KEY=your-emergent-key-here
LLM_PROVIDER=claude
LLM_MODEL=claude-sonnet-4-5-20250929

# Service URLs (for Docker Compose)
MCP_SERVICE_URL=http://localhost:8001/api/mcp
ONBOARDING_AGENT_URL=http://localhost:8001/api/agents/onboarding

# CORS
CORS_ORIGINS=*

# Frontend
REACT_APP_BACKEND_URL=http://localhost:8001
