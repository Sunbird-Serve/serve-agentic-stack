# SERVE AI Platform - Environment Variables
# Copy this file to .env and fill in values

# LLM Configuration (required for onboarding agent)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Service Ports (defaults shown)
# ORCHESTRATOR_PORT=8001
# ONBOARDING_AGENT_PORT=8002
# MCP_SERVICE_PORT=8003
# FRONTEND_PORT=3000

# WhatsApp Cloud API (Meta WABA)
WHATSAPP_TOKEN=your-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_APP_SECRET=your-app-secret
WHATSAPP_VERIFY_TOKEN=serve_verify_token

# Volunteer Registration URL — shown to unregistered recommended volunteers
# Default: https://up.serve.net.in
# VOLUNTEER_REGISTRATION_URL=https://up.serve.net.in
